{
  "name": "piano-teacher",
  "version": "1.3.1",
  "description": "An interactive way to learn piano using a visual piano interface.",
  "author": "Callum O'Prey callumoprey@gmail.com",
  "scripts": {
    "test": "jest",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:arm64": "tauri build --target aarch64-pc-windows-msvc --no-bundle",
    "tauri:build:x64": "tauri build --target x86_64-pc-windows-msvc --no-bundle",
    "tauri:pack:arm64": "powershell -ExecutionPolicy Bypass -File ./src-tauri/msix/pack.ps1 -Arch arm64",
    "tauri:pack:x64": "powershell -ExecutionPolicy Bypass -File ./src-tauri/msix/pack.ps1 -Arch x64",
    "tauri:bundle": "powershell -ExecutionPolicy Bypass -File ./src-tauri/msix/bundle.ps1",
    "tauri:clean": "powershell -Command \"if (Test-Path 'dist') { Remove-Item -Recurse -Force 'dist' }\"",
    "build-store": "npm run tauri:clean && npm run tauri:build:arm64 && npm run tauri:build:x64 && npm run tauri:pack:arm64 && npm run tauri:pack:x64 && npm run tauri:bundle"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": [
      "<rootDir>/build"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/android/",
      "/dist/"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@tauri-apps/cli": "^2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0"
  }
}
