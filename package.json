{
  "name": "piano-teacher",
  "version": "1.2.2",
  "description": "An interactive way to learn piano using a visual piano interface.",
  "author": "Callum O'Prey callumoprey@gmail.com",
  "main": "main.js",
  "scripts": {
    "build": "electron-builder --win appx",
    "test": "jest",
    "desktop": "electron .",
    "build-store": "npx electron-builder --win appx --x64 --arm64"
  },
  "jest": {
    "testEnvironment": "jsdom"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@electron/remote": "^2.1.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "electron": "^33.4.11",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0"
  },
  "build": {
    "appx": {
      "identityName": "Callum-OP.PianoTeacherbyCallum-OP",
      "publisher": "CN=08FEADE4-7024-438F-99AB-86942FD832C3",
      "publisherDisplayName": "Callum-OP",
      "displayName": "Piano Teacher by Callum-OP",
      "applicationId": "PianoTeacherbyCallumOP",
      "backgroundColor": "#F0E4D0"
    },
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "build/sounds/*"
    ],
    "win": {
      "target": "appx",
      "icon": "build/icon.ico"
    }
  }
}
