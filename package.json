{
  "name": "piano-teacher",
  "version": "1.3.0",
  "description": "An interactive way to learn piano using a visual piano interface.",
  "author": "Callum O'Prey callumoprey@gmail.com",
  "main": "main.js",
  "scripts": {
    "build": "npx electron-builder --win appx --x64 --arm64",
    "test": "jest",
    "desktop": "electron .",
    "delete-dist": "rmdir /s /q \"dist\"",
    "isolate-appx": "powershell -Command \"New-Item -ItemType Directory -Force 'dist/piano-teacher-bundle'; Move-Item 'dist/*.appx' 'dist/piano-teacher-bundle/' -ErrorAction SilentlyContinue\"",
    "bundle": "powershell -Command \"& 'C:/Program Files (x86)/Windows Kits/10/bin/10.0.26100.0/arm64/MakeAppx.exe' bundle /v /d 'dist/piano-teacher-bundle' /p \\\"dist/piano-teacher.$env:npm_package_version.appxbundle\\\"\"",
    "build-store": "npm run delete-dist && npm run build && npm run isolate-appx && npm run bundle"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": [
      "<rootDir>/build"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/android/",
      "/dist/"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@electron/remote": "^2.1.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "electron": "^33.4.11",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0"
  },
  "build": {
    "appx": {
      "identityName": "Callum-OP.PianoTeacherbyCallum-OP",
      "publisher": "CN=08FEADE4-7024-438F-99AB-86942FD832C3",
      "publisherDisplayName": "Callum-OP",
      "displayName": "Piano Teacher by Callum-OP",
      "applicationId": "PianoTeacherbyCallumOP",
      "backgroundColor": "#F0E4D0",
      "minVersion": "10.0.19041.0"
    },
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "build/sounds/*"
    ],
    "win": {
      "target": "appx",
      "icon": "build/icon.ico"
    }
  }
}
